{
  "name": "resq-box",
  "version": "1.0.0",
  "type": "module",
  "description": "Gamified STEM Disaster Education Kit — drag & drop block coding with Arduino simulation",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite dev --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "blockly": "^11.2.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "serialport": "^12.0.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
